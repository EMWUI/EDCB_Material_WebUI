-- vim:set ft=lua:
dofile(mg.script_name:gsub('[^\\/]*$','')..'util.lua')

a={err='不正値入力'}
post=AssertPost()
if post then
  dataID=GetVarInt(mg.request_info.query_string,'id') or 0
  aa={dataID=dataID}
  if mg.get_var(post,'addchg') then
    aa.recSetting=GetRecSetting(post)
    if aa.recSetting then
      aa.searchInfo=GetSearchKey(post)
      done=edcb.AddOrChgAutoAdd(aa)
      if done then
        a={success='EPG自動予約を'..(aa.dataID==0 and '追加' or '変更')..'しました'}
      else
        a={err='EPG自動予約を'..(aa.dataID==0 and '追加' or '変更')..'できませんでした'}
      end
    end
  elseif mg.get_var(post,'del') then
    edcb.DelAutoAdd(aa.dataID)
    a={success='EPG自動予約を削除しました'}
  end
end

if GetVarInt(mg.request_info.query_string,'json')==1 then
  ResponseJson(a)
else
  ResponseXml(a)
end
